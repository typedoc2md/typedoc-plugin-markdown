{
  "compilerOptions": {
    "skipLibCheck": true,
    "experimentalDecorators": false,
    "esModuleInterop": true,
    "declaration": true,
    "lib": ["es2022", "dom", "esnext.disposable"],
    "module": "node16",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "target": "es2022"
  }
}
